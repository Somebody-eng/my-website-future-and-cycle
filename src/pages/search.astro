---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import SearchBox from "@components/SearchBox.astro";
import { getPublishedPosts } from "@lib/posts";

const posts = await getPublishedPosts();
const index = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags,
  url: `/posts/${post.slug}/`,
  date: post.data.date.toLocaleDateString("zh-CN")
}));
---

<BaseLayout title="搜索" description="搜索未来与周期的商业思想、长期主义与企业案例文章。" canonical="/search/">
  <section class="section search-page">
    <div class="container search-inner">
      <Breadcrumb items={[{ label: "搜索" }]} />
      <header>
        <p>SEARCH THE ARCHIVE</p>
        <h1>搜索研究笔记</h1>
        <span>按关键词、人物、栏目或标签查找文章。</span>
      </header>
      <SearchBox />
      <div class="result-meta"><span id="result-count"></span></div>
      <div id="search-results" class="results" aria-live="polite"></div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ index }}>
  const input = document.querySelector("#site-search");
  const results = document.querySelector("#search-results");
  const count = document.querySelector("#result-count");

  function escapeHtml(value) {
    return String(value).replace(/[&<>'"]/g, (character) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", "'": "&#39;", '"': "&quot;"
    }[character]));
  }

  function render(items) {
    if (!results) return;
    if (count) count.textContent = `共 ${items.length} 篇`;
    if (!items.length) {
      results.innerHTML = "<p class='empty'>没有找到匹配文章，试试更短的关键词。</p>";
      return;
    }
    results.innerHTML = items.map((item, index) => `
      <article class="result-item">
        <span class="result-number">${String(index + 1).padStart(2, "0")}</span>
        <div>
          <small>${escapeHtml(item.category)} · ${escapeHtml(item.date)}</small>
          <h2><a href="${item.url}">${escapeHtml(item.title)}</a></h2>
          <p>${escapeHtml(item.description)}</p>
        </div>
      </article>
    `).join("");
  }

  function search(value) {
    const keyword = value.trim().toLowerCase();
    const matches = keyword ? index.filter((item) =>
      [item.title, item.description, item.category, item.tags.join(" ")]
        .join(" ").toLowerCase().includes(keyword)
    ) : index;
    render(matches);
  }

  input?.addEventListener("input", (event) => search(event.target.value));
  render(index);
</script>

<style>
  .search-page { padding-top: 34px; }
  .search-inner { max-width: 860px; }
  header { margin: 48px 0 30px; }
  header p { margin: 0 0 14px; color: var(--accent); font-size: 12px; font-weight: 700; }
  h1 { margin: 0; font-size: 42px; line-height: 1.18; }
  header span { display: block; margin-top: 14px; color: var(--muted); }
  .result-meta { min-height: 45px; padding-top: 24px; color: var(--muted); font-size: 13px; }
  .results { border-top: 1px solid var(--line); }
  :global(.result-item) { display: grid; grid-template-columns: 42px 1fr; gap: 18px; padding: 26px 0; border-bottom: 1px solid var(--line); }
  :global(.result-number) { color: var(--accent); font-size: 12px; font-weight: 700; }
  :global(.result-item small) { color: var(--muted); }
  :global(.result-item h2) { margin: 7px 0 8px; font-size: 21px; }
  :global(.result-item a) { color: var(--text); text-decoration: none; }
  :global(.result-item a:hover) { color: var(--accent); }
  :global(.result-item p) { margin: 0; color: var(--muted); line-height: 1.75; }
  :global(.empty) { padding: 34px 0; color: var(--muted); }
  @media (max-width: 640px) {
    .search-page { padding-top: 22px; }
    header { margin: 30px 0 24px; }
    h1 { font-size: 32px; }
    :global(.result-item) { grid-template-columns: 30px 1fr; gap: 10px; }
  }
</style>
