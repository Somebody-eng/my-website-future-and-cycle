---
import { Rss } from "@lucide/astro";
import { SITE_SHORT_NAME } from "@lib/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>© {year} {SITE_SHORT_NAME} · 长期主义商业思想笔记</div>
    <nav aria-label="页脚导航">
      <a href="/about/">关于我们</a>
      <a href="/privacy/">隐私政策</a>
      <a href="/disclaimer/">免责声明</a>
      <a href="/contact/">联系</a>
      <a href="/rss.xml"><Rss size={14} stroke-width={1.5} aria-hidden="true" />RSS</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-left: var(--rail-width);
    padding: 26px 0;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.72rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    width: min(1280px, calc(100% - 80px));
    margin: 0 auto;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .site-footer {
      margin-left: 0;
      padding: 24px 0 94px;
    }

    .footer-inner {
      display: grid;
      width: calc(100% - 32px);
    }

    nav {
      flex-wrap: wrap;
      gap: 12px 20px;
    }
  }
</style>
