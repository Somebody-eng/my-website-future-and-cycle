---
interface Item {
  label: string;
  href?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="面包屑导航">
  <a href="/">首页</a>
  {items.map((item) => (
    <>
      <span aria-hidden="true">/</span>
      {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
    </>
  ))}
</nav>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 9px;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .breadcrumb a,
  .breadcrumb span:last-child {
    overflow: hidden;
    color: var(--muted);
    text-decoration: none;
    text-overflow: ellipsis;
  }

  @media (max-width: 720px) {
    .breadcrumb a:first-child,
    .breadcrumb span[aria-hidden="true"]:first-of-type {
      display: none;
    }
  }
</style>
